{
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./js",
    "target": "es6",
    "module": "es2020",
    "lib": ["dom", "es2020"],
    "sourceMap": true,
    "strict": true,
    "jsx": "react-jsx",
    "isolatedModules": true,
    "moduleDetection": "force",
    "skipLibCheck": true,
  }
}
